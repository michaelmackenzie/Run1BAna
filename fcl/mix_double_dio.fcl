#include "Production/JobConfig/mixing/Mix.fcl"

# Add a mixer to mix in 1 DIO per event, reuse mustop pileup name
physics.producers.DIOFilter : @local::physics.producers.MuStopPileupFilter
physics.producers.DIOFilter.MixingModule: "DIOMixer"
physics.filters.DIOMixer : @local::Mixing.DetStepMixer
physics.filters.DIOMixer.mu2e.MaxEventsToSkip: 0
physics.filters.DIOMixer.mu2e.simStageEfficiencyTags: []
physics.filters.DIOMixer.mu2e.forceNSecondaries : 1

services.DbService.purpose: "Sim_best"
services.DbService.version: "v1_1"
source.firstRun: 1440 #TODO
source.inputCommands : [ "keep *", "drop art::TriggerResults_*_*_*" ]

physics.filters.GenFilter : {
  module_type             : DoubleGenFilter
  StageParticleCollection : "NOTUSED"
  SimParticleCollection   : "compressDigiMCs"
  maxDeltaT               : 1.e10
  maxDeltaRCalo           : 1.e12
  minTotalEnergy          : 80.
  diagLevel               : 0
  doHistograms            : true
}

physics.MixSequence : [PBISim, DTSFilter, DIOMixer, DIOFilter]
physics.TriggerableCaloPath : [ @sequence::physics.MixSequence, GenFilter, @sequence::Digitize.TriggerableCaloSequence ]

physics.DigitizePath : [
  @sequence::physics.MixSequence,
  @sequence::Digitize.DigitizeSequence ]

#include "Production/JobConfig/mixing/OneBB.fcl"
#include "Production/JobConfig/digitize/OnSpill_run1b_epilog.fcl"

physics.trigger_paths : [ "DigitizePath" ]

physics.producers.compressDigiMCs.simParticleTags            : [compressDetStepMCs, DIOMixer  ]
physics.producers.makeSD.StrawGasStepModules                 : [compressDetStepMCs, DIOFilter ]
physics.producers.compressDigiMCs.caloShowerStepTags         : [compressDetStepMCs, DIOFilter ]
physics.producers.CaloShowerROMaker.caloShowerStepCollection : [compressDetStepMCs, DIOFilter ]
physics.producers.CrvPhotons.crvStepModuleLabels             : [compressDetStepMCs, DIOFilter ]
physics.producers.CrvPhotons.crvStepProcessNames             : [ "",""]

